# ============================================
# TactoFlow Production Environment Variables
# ============================================
# Copy this file to .env.production and fill in the values

# ===========================================
# Application
# ===========================================
APP_NAME=TactoFlow
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production

# ===========================================
# Database (PostgreSQL)
# ===========================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=tacto
DB_PASSWORD=your-secure-database-password
DB_NAME=tacto_db
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ===========================================
# Redis
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===========================================
# Tacto External API
# ===========================================
TACTO_API_BASE_URL=https://api-externa.tactonuvem.com.br
TACTO_AUTH_URL=https://accounts.tactonuvem.com.br/connect/token
TACTO_CLIENT_ID=integracao-externa
TACTO_CLIENT_SECRET=your-tacto-client-secret
TACTO_CHAVE_ORIGEM=your-chave-origem
TACTO_HTTP_TIMEOUT=120

# ===========================================
# Join Developer API (WhatsApp)
# ===========================================
JOIN_API_BASE_URL=https://api-prd.joindeveloper.com.br
JOIN_TOKEN_CLIENTE=your-join-token
JOIN_HTTP_TIMEOUT=30

# ===========================================
# Google Gemini AI
# ===========================================
GOOGLE_API_KEY=your-google-api-key
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/embedding-001
EMBEDDING_DIMENSION=768
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.7

# ===========================================
# API Port (external)
# ===========================================
API_PORT=8000
