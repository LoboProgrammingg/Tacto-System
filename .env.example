# =============================================================================
# Tacto-System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=TactoFlow
APP_VERSION=0.0.1
DEBUG=false
SECRET_KEY=change-me-in-production

# AI behaviour
AI_DISABLE_HOURS=12                  # Hours AI stays off after human operator takes over a conversation
AI_REOPEN_BUFFER_MINUTES=10          # Minutes before restaurant opens to re-enable AI (restaurant_closed case)
CONVERSATION_HISTORY_LIMIT=10        # Max recent messages injected into LLM context

# Testing / override flags
BYPASS_HOURS_CHECK=false             # Set to true to treat every restaurant as OPEN (local testing only!)

# Locale
DEFAULT_TIMEZONE=America/Sao_Paulo   # Default timezone used when restaurant has none set

# Security — API Key and CORS
API_KEY=                             # If set, requires X-API-Key header on all requests (except health/webhooks)
RATE_LIMIT_RPM=60                    # Requests per minute per IP (0 = disabled)
CORS_ORIGINS=                        # Comma-separated allowed origins (empty = DEBUG mode default)
                                     # Example: https://app.example.com,https://admin.example.com

# AI Assistant Identity
ATTENDANT_NAME=Maria                 # AI attendant persona name (used in prompts)

# Circuit Breaker (external API resilience)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5  # Failures before opening circuit
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30  # Seconds before testing recovery

# Memory Retrieval Limits
MEMORY_SHORT_TERM_LIMIT=20           # Max short-term memory entries to load
MEMORY_MEDIUM_TERM_LIMIT=5           # Max medium-term memory entries to load
MEMORY_LONG_TERM_LIMIT=10            # Max long-term memory entries to load

# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=tacto
DB_PASSWORD=tacto
DB_NAME=tacto_db
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_BUFFER_TTL=5                   # Generic buffer TTL (seconds)
REDIS_MEMORY_TTL=3600                # Conversation memory TTL (seconds, 1h)
REDIS_BUFFER_WINDOW_SECONDS=5        # Wait window before processing buffered messages
REDIS_BUFFER_LOCK_TTL=10             # Distributed lock TTL for buffer processing (seconds)
REDIS_ECHO_TRACKER_TTL=5             # TTL for tracking AI-sent phone numbers (seconds)
REDIS_MSG_ID_TRACKER_TTL=300         # TTL for tracking AI-sent message IDs (seconds, 5min)

# -----------------------------------------------------------------------------
# Google Gemini AI
# -----------------------------------------------------------------------------

# Credentials & Embedding (shared across all agent levels)
GOOGLE_API_KEY=                      # Your Google AI Studio / Vertex API key
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768

# Global defaults — fallback values used when no per-level override is set
LLM_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=3000
GEMINI_TEMPERATURE=0.7
RAG_SEARCH_LIMIT=10                  # Default max menu items returned by semantic search

# Level 1 Agent — conversational assistant (basic automation)
# To add Level 2, create a LEVEL2_* block following the same pattern below
LEVEL1_LLM_MODEL=gemini-2.5-flash
LEVEL1_TEMPERATURE=0.7
LEVEL1_MAX_TOKENS=3000
LEVEL1_RAG_SEARCH_LIMIT=10           # Menu items injected into Level1 context

# -----------------------------------------------------------------------------
# Join Developer API (WhatsApp gateway)
# -----------------------------------------------------------------------------
JOIN_API_BASE_URL=https://api-prd.joindeveloper.com.br
JOIN_TOKEN_CLIENTE=                  # Your Join API token
JOIN_HTTP_TIMEOUT=30

# Typing simulation (humanized delay before sending — makes AI feel more human)
JOIN_TYPING_CHARS_PER_SEC=40         # Estimated typing speed (chars/sec)
JOIN_TYPING_VARIANCE=0.20            # ±20% random variance on delay
JOIN_TYPING_MIN_MS=2000              # Minimum delay in milliseconds
JOIN_TYPING_MAX_MS=12000             # Maximum delay in milliseconds

# Webhook security — HMAC signature validation
JOIN_WEBHOOK_SECRET=                 # If set, validates X-Hub-Signature-256 header on webhooks
                                     # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Retry policy (exponential backoff on 502/503/504 and transport errors)
JOIN_RETRY_MAX_ATTEMPTS=3            # Max number of retry attempts
JOIN_RETRY_BASE_DELAY=1.0            # Base delay in seconds (doubles each attempt)

# -----------------------------------------------------------------------------
# Tacto External API (menu / cardápios)
# -----------------------------------------------------------------------------
TACTO_API_BASE_URL=https://api-externa.tactonuvem.com.br
TACTO_AUTH_URL=https://accounts.tactonuvem.com.br/connect/token
TACTO_CLIENT_ID=integracao-externa
TACTO_CLIENT_SECRET=                 # Your Tacto OAuth2 client secret
TACTO_CHAVE_ORIGEM=                  # Chave de origem para autenticação Tacto
TACTO_HTTP_TIMEOUT=120
TACTO_MENU_CACHE_TTL=3600            # Redis cache TTL for menu data (seconds, 1h)
TACTO_INSTITUTIONAL_CACHE_TTL=86400  # Redis cache TTL for institutional data (seconds, 24h)

# -----------------------------------------------------------------------------
# LangSmith (Observability — optional but recommended)
# -----------------------------------------------------------------------------
LANGSMITH_TRACING=false              # Set to true to enable LangSmith tracing
LANGSMITH_API_KEY=                   # Your LangSmith API key
LANGSMITH_PROJECT=Tacto-System
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
