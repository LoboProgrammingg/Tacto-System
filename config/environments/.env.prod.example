# ============================================================
# TactoFlow — PRODUÇÃO (.env.prod)
# Copie este arquivo, preencha os valores e salve como GitHub
# Secret ENV_PROD (sem os comentários).
# ============================================================

# App
APP_NAME=TactoFlow
APP_VERSION=0.0.1
DEBUG=false
SECRET_KEY=GERE_COM_python_-c_"import secrets; print(secrets.token_urlsafe(32))"
BYPASS_HOURS_CHECK=false
DEFAULT_TIMEZONE=America/Cuiaba

# AI behaviour
AI_DISABLE_HOURS=12
AI_REOPEN_BUFFER_MINUTES=10
CONVERSATION_HISTORY_LIMIT=10

# Database (Docker resolve internamente — não altere DB_HOST/DB_PORT)
DB_HOST=postgres
DB_PORT=5432
DB_USER=tacto
DB_PASSWORD=SUA_SENHA_FORTE
DB_NAME=tacto_db
DB_ECHO=false
API_PORT=8000

# Redis (Docker resolve internamente)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_BUFFER_TTL=5
REDIS_MEMORY_TTL=3600
REDIS_BUFFER_WINDOW_SECONDS=8
REDIS_BUFFER_LOCK_TTL=10
REDIS_ECHO_TRACKER_TTL=5
REDIS_MSG_ID_TRACKER_TTL=300

# Tacto API
TACTO_API_BASE_URL=https://api-externa.tactonuvem.com.br
TACTO_AUTH_URL=https://accounts.tactonuvem.com.br/connect/token
TACTO_CLIENT_ID=integracao-externa
TACTO_CLIENT_SECRET=SEU_CLIENT_SECRET
TACTO_DEFAULT_SCOPE=None
TACTO_HTTP_TIMEOUT=120
TACTO_CHAVE_ORIGEM=SEU_UUID_CHAVE_ORIGEM
TACTO_MENU_CACHE_TTL=3600
TACTO_INSTITUTIONAL_CACHE_TTL=86400

# Join Developer
JOIN_TOKEN_CLIENTE=SEU_TOKEN_JOIN
JOIN_API_BASE_URL=https://api-prd.joindeveloper.com.br
JOIN_HTTP_TIMEOUT=30
JOIN_TYPING_CHARS_PER_SEC=40
JOIN_TYPING_VARIANCE=0.20
JOIN_TYPING_MIN_MS=2000
JOIN_TYPING_MAX_MS=12000
JOIN_RETRY_MAX_ATTEMPTS=3
JOIN_RETRY_BASE_DELAY=1.0

# Google Gemini
GOOGLE_API_KEY=SUA_GOOGLE_API_KEY
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768
LLM_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=3000
GEMINI_TEMPERATURE=0.7
RAG_SEARCH_LIMIT=10

# Level 1 Agent
LEVEL1_LLM_MODEL=gemini-2.5-flash
LEVEL1_TEMPERATURE=0.7
LEVEL1_MAX_TOKENS=3000
LEVEL1_RAG_SEARCH_LIMIT=10

# LangSmith (observabilidade)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=SUA_LANGSMITH_KEY
LANGSMITH_PROJECT="Tacto-System-Prod"
