# ═══════════════════════════════════════════════════════════════════════════════
# TACTOFLOW — DEVELOPMENT ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════════════
# Branch: dev, feature/*, bugfix/*
# Purpose: Local development with hot-reload, debug logging
#
# HOW IT WORKS:
#   This file is committed and overrides base settings for local dev.
#   Credentials (API keys, tokens) come from .env (git-ignored, local only).
#   Load order: .env → this file → .env.local
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Environment Identification
# ─────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_NAME=TactoFlow-Dev
APP_VERSION=0.0.1-dev
DEBUG=true

# Security — relaxed for dev (real SECRET_KEY comes from .env)
SECRET_KEY=dev-secret-key-not-for-production

# ─────────────────────────────────────────────────────────────────────────────
# Database — Local Docker (non-standard ports to avoid conflicts)
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USER=tacto
DB_PASSWORD=tacto
DB_NAME=tacto_db
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ─────────────────────────────────────────────────────────────────────────────
# Redis — Local Docker (non-standard port to avoid conflicts)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_BUFFER_TTL=5
REDIS_MEMORY_TTL=3600
REDIS_BUFFER_WINDOW_SECONDS=8
REDIS_BUFFER_LOCK_TTL=10
REDIS_ECHO_TRACKER_TTL=5
REDIS_MSG_ID_TRACKER_TTL=300

# ─────────────────────────────────────────────────────────────────────────────
# Tacto External API — URLs (credentials come from .env)
# ─────────────────────────────────────────────────────────────────────────────
TACTO_API_BASE_URL=https://api-externa.tactonuvem.com.br
TACTO_AUTH_URL=https://accounts.tactonuvem.com.br/connect/token
TACTO_HTTP_TIMEOUT=120
TACTO_MENU_CACHE_TTL=3600
TACTO_INSTITUTIONAL_CACHE_TTL=86400

# ─────────────────────────────────────────────────────────────────────────────
# Join Developer API — URLs (credentials come from .env)
# ─────────────────────────────────────────────────────────────────────────────
JOIN_API_BASE_URL=https://api-prd.joindeveloper.com.br
JOIN_HTTP_TIMEOUT=30
JOIN_TYPING_CHARS_PER_SEC=40
JOIN_TYPING_VARIANCE=0.20
JOIN_TYPING_MIN_MS=2000
JOIN_TYPING_MAX_MS=12000
JOIN_RETRY_MAX_ATTEMPTS=3
JOIN_RETRY_BASE_DELAY=1.0

# ─────────────────────────────────────────────────────────────────────────────
# AI Configuration — Model/behavior (API key comes from .env)
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768
LLM_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=3000
GEMINI_TEMPERATURE=0.7
RAG_SEARCH_LIMIT=10
LEVEL1_LLM_MODEL=gemini-2.5-flash
LEVEL1_TEMPERATURE=0.7
LEVEL1_MAX_TOKENS=3000
LEVEL1_RAG_SEARCH_LIMIT=10

# ─────────────────────────────────────────────────────────────────────────────
# Development-Specific Settings
# ─────────────────────────────────────────────────────────────────────────────
BYPASS_HOURS_CHECK=true
DEFAULT_TIMEZONE=America/Cuiaba
CORS_ORIGINS=http://localhost:3000,http://localhost:8100
RATE_LIMIT_RPM=0
AI_DISABLE_HOURS=12
AI_REOPEN_BUFFER_MINUTES=10
CONVERSATION_HISTORY_LIMIT=10

# ─────────────────────────────────────────────────────────────────────────────
# Observability — LangSmith disabled locally (API key comes from .env if needed)
# ─────────────────────────────────────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=tactoflow-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LOG_LEVEL=DEBUG
